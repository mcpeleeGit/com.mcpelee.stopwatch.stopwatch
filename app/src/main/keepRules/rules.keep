# This app has no reflection, serialization, WebView bridge, or network SDKs.
# Keep this file intentionally small so R8 can shrink and obfuscate app code.

-renamesourcefileattribute SourceFile
-keepattributes SourceFile,LineNumberTable

# Strip verbose/debug/info logs from optimized release builds if any are added later.
-assumenosideeffects class android.util.Log {
    public static int v(...);
    public static int d(...);
    public static int i(...);
}
